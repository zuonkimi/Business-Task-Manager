<nav class="navbar">
  <!-- LEFT -->
  <div class="nav-left">
    <button class="btn btn-dark d-md-none me-2" onclick="sidebarToggle()">
      <i class="bi bi-three-dots-vertical"></i>
    </button>
    <a class="navbar-brand" href="/">
      <img src="/img/img1.png" class="logo-header" alt="logo" />
      Zuno Pulse
    </a>
  </div>

  <!-- CENTER -->
  <div class="nav-center">
    <form method="GET" action="/search" class="search-wrapper">
      <input
        type="text"
        name="keyword"
        class="search-box"
        placeholder="Search tasks / documents / users..."
        value="{{activeFilter.keyword}}"
      />
      <button type="submit" class="search-btn">
        <i class="bi bi-search search-icon"></i>
      </button>
    </form>
  </div>

  <!-- RIGHT -->
  <div class="nav-right">
    <!-- NOTIFICATION -->
    <div class="dropdown notification-dropdown">
      <!-- DESKTOP -->
      <button
        class="btn btn-dark position-relative d-none d-md-inline-flex"
        data-bs-toggle="dropdown"
      >
        <i class="bi bi-bell-fill"></i>
        {{#if unreadCount}}
        <span class="notification-badge">
          {{#if (gt unreadCount 99)}}99+{{else}}{{unreadCount}}{{/if}}
        </span>
        {{/if}}
      </button>
      <!-- MOBILE -->
      <a
        href="/notifications"
        class="btn btn-dark position-relative d-inline-flex d-md-none"
      >
        <i class="bi bi-bell-fill"></i>
        {{#if unreadCount}}
        <span class="notification-badge">
          {{#if (gt unreadCount 99)}}99+{{else}}{{unreadCount}}{{/if}}
        </span>
        {{/if}}
      </a>
      <!-- DROPDOWN -->
      <div class="dropdown-menu dropdown-menu-end notification-menu">
        <div class="notification-menu-header">
          <span>Notifications</span>
          {{#if unreadCount}}
          <form action="/notifications/read-all" method="POST">
            <button type="submit" class="mark-all-btn">Mark all read</button>
          </form>
          {{/if}}
        </div>
        {{#if notifications.length}}
        <div class="notification-menu-list">
          {{#each notifications}}
          <a
            href="/notifications/{{this._id}}/redirect"
            class="notification-card {{#unless this.isRead}}unread{{/unless}}"
          >
            <div class="notification-card-avatar">
              <img src="{{this.sender.avatar}}" alt="{{this.sender.name}}" />
            </div>
            <div class="notification-card-content">
              <div class="notification-card-text">
                <strong>{{this.sender.name}}</strong>
                {{#if (eq this.type "comment")}} commented on your task {{/if}}
                {{#if (eq this.type "like_comment")}} liked your comment {{/if}}
                {{#if (eq this.type "like_task")}} liked your task {{/if}} {{#if
                (eq this.type "reply")}} replied to your comment {{/if}} {{#if
                (eq this.type "follow")}} followed you {{/if}} {{#if (eq
                this.type "new_task")}} created a new task {{/if}}
              </div>
              <div class="notification-card-time">
                {{timeAgo this.createdAt}}
              </div>
            </div>
          </a>
          {{/each}}
        </div>
        {{else}}
        <div class="empty-notification">
          <i class="bi bi-bell"></i>
          <p>No notifications yet</p>
        </div>
        {{/if}}
        <div class="notification-menu-footer">
          <a href="/notifications"> View all notifications </a>
        </div>
      </div>
    </div>

    <!-- PROFILE -->
    <div class="avatar avatar-md">
      <a href="/profile/{{currentUser._id}}">
        <img src="{{currentUser.avatar}}" alt="{{currentUser.name}}" />
      </a>
    </div>

    <!-- MENU -->
    <div class="dropdown">
      <button class="btn btn-dark dropdown-toggle" data-bs-toggle="dropdown">
        Menu <i class="bi bi-list"></i>
      </button>
      <div class="dropdown-menu">
        <a href="/profile/{{currentUser._id}}">
          <i class="bi bi-person-circle"></i>
          Profile
        </a>

        <a href="#">
          <i class="bi bi-gear"></i>
          Settings
        </a>

        <a href="/auth/logout">
          <i class="bi bi-box-arrow-right"></i>
          Logout
        </a>
      </div>
    </div>
  </div>
</nav>

<!-- MOBILE SEARCH OVERLAY -->
<div class="search-overlay">
  <div class="search-overlay__box">
    <form method="GET" action="/search" class="search-wrapper">
      <input
        type="text"
        name="keyword"
        class="search-box"
        placeholder="Search tasks / documents / users..."
      />
      <button type="submit" class="search-btn">
        <i class="bi bi-search search-icon"></i>
      </button>
    </form>
  </div>
</div>

<!-- SCRIPT -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const overlay = document.querySelector('.search-overlay');
    const navSearchBtn = document.querySelector('.nav-center .search-btn');
    if (!overlay || !navSearchBtn) return;
    const input = overlay.querySelector('input[name="keyword"]');
    navSearchBtn.addEventListener('click', event => {
      if (window.innerWidth > 600) return;
      event.preventDefault();
      overlay.classList.add('active');
      requestAnimationFrame(() => {
        input?.focus();
      });
    });
    overlay.addEventListener('click', event => {
      if (event.target === overlay) {
        overlay.classList.remove('active');
      }
    });
    document.addEventListener('keydown', event => {
      if (event.key === 'Escape') {
        overlay.classList.remove('active');
      }
    });
  });
</script>
