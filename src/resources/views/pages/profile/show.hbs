<div class="profile-page">
  <section class="profile-card">
    <!-- HEADER -->
    <div class="profile-header">
      <div class="profile-avatar">
        {{#if user.avatar}}
        <img src="{{user.avatar}}" />
        {{else}}
        <div class="avatar-fallback">{{user.name.[0]}}</div>
        {{/if}}
      </div>
      <div class="profile-info">
        <h2>{{user.name}}</h2>
        <p class="email">{{user.email}}</p>
        <p class="bio">
          {{#if user.bio}} {{user.bio}} {{else}} No bio yet {{/if}}
        </p>
      </div>
    </div>

    <!-- ACTION -->
    <div class="profile-action">
      {{#if isOwner}}
      <a href="/profile/{{user._id}}/edit" class="btn btn-edit">
        Edit Profile
      </a>
      {{else}}
      <button
        class="btn btn-follow {{#if isFollowing}}active{{/if}}"
        onclick="{{#if isFollowing}}unfollow('{{user._id}}', this){{else}}follow('{{user._id}}', this){{/if}}"
      >
        {{#if isFollowing}}Following{{else}}Follow{{/if}}
      </button>
      {{/if}}
    </div>

    <!-- STATS -->
    <div class="profile-stats">
      <div class="stat">
        <strong>{{stats.total}}</strong>
        <span>Posts</span>
      </div>
      <div class="stat">
        <strong>{{stats.followers}}</strong>
        <span>Followers</span>
      </div>
      <div class="stat">
        <strong>{{stats.following}}</strong>
        <span>Following</span>
      </div>
      <div class="stat">
        <strong>{{stats.done}}</strong>
        <span>Done</span>
      </div>
    </div>
  </section>

  <!-- POSTS -->
  <section class="profile-posts">
    <div class="section-title">Recent Activity</div>
    {{#if posts.length}}
    <div class="post-grid">
      {{#each posts}}
      <a href="/tasks/{{this._id}}" class="post-card">
        {{#if this.attachments}}
        <img src="{{this.attachments.[0].url}}" />
        {{/if}}
        <div class="post-body">
          <h4>{{this.title}}</h4>
          {{#if this.description}}
          <p>{{this.description}}</p>
          {{/if}}
          <div class="post-meta">
            <span>{{formatDate this.createdAt}}</span>
            <span class="badge">{{this.status}}</span>
          </div>
        </div>
      </a>
      {{/each}}
    </div>
    {{else}}
    <div class="empty-state">No activity yet</div>
    {{/if}}
  </section>
</div>

<script>
  async function follow(userId, btn) {
    btn.disabled = true;
    try {
      const res = await fetch(`/api/follow/${userId}`, {
        method: 'POST',
      });
      const data = await res.json();
      if (data.following) {
        btn.innerText = 'Following';
        btn.classList.remove('btn-primary');
        btn.classList.add('btn-secondary');
        btn.onclick = () => unfollow(userId, btn);
      }
    } catch (err) {
      console.error(err);
    }
    btn.disabled = false;
  }
  async function unfollow(userId, btn) {
    btn.disabled = true;
    try {
      const res = await fetch(`/api/follow/${userId}`, {
        method: 'DELETE',
      });
      const data = await res.json();
      if (!data.following) {
        btn.innerText = 'Follow';
        btn.classList.remove('btn-secondary');
        btn.classList.add('btn-primary');
        btn.onclick = () => follow(userId, btn);
      }
    } catch (err) {
      console.error(err);
    }
    btn.disabled = false;
  }
</script>
