<div class="task-form">
  <div class="task-list-header">
    <h2 class="mb-0"><i class="bi bi-window-plus"></i> Create Post</h2>
    <button class="btn btn-outline-secondary" onclick="goBackPrevPage()">
      Back
    </button>
  </div>

  <form
    action="/tasks/store"
    method="POST"
    enctype="multipart/form-data"
    class="mt-3"
  >
    <input type="hidden" name="_csrf" value="{{csrfToken}}" />
    <!-- TITLE -->
    <div class="mb-3">
      <input
        name="title"
        class="form-control"
        placeholder="Tiêu đề..."
        required
      />
    </div>
    <!-- DESCRIPTION -->
    <div class="mb-3">
      <textarea
        name="description"
        class="form-control"
        placeholder="Ghi chú..."
      ></textarea>
    </div>
    <!-- FILE -->
    <div class="mb-3">
      <input
        type="file"
        name="attachments"
        class="form-control"
        multiple
        accept="image/*,application/pdf"
      />
    </div>
    <!-- PREVIEW -->
    <div id="preview" class="preview"></div>
    <!-- DEADLINE + TAG -->
    <div class="row g-2">
      <div class="col-12 col-md-6">
        <input type="date" name="deadline" class="form-control" />
      </div>
      <div class="col-12 col-md-6">
        <select name="tags" class="form-control">
          <option value="">--- Select tag ---</option>
          <option value="請求書">請求書</option>
          <option value="安全書類">安全書類</option>
          <option value="発注">発注</option>
          <option value="注文請書">注文請書</option>
          <option value="リモート">リモート</option>
          <option value="領収書">領収書</option>
          <option value="他">他</option>
        </select>
      </div>
    </div>
    <button type="submit" class="btn btn-primary mt-3">Post</button>
  </form>
</div>

<script>
  // BACK
  const goBackPrevPage = () => {
    if (window.history.length > 1) {
      window.history.go(-1);
    } else {
      window.location.href = '/tasks';
    }
  };
</script>
