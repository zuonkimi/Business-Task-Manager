<div class="task-list-container mt-4">
  <!-- HEADER -->
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h2 class="fw-semibold">Task Management</h2>
      <small class="text-muted">Manage all your tasks</small>
    </div>
    <a href="/tasks/create" class="btn btn-primary"> + Create Task </a>
  </div>
  <!-- FILTER BAR -->
  <div class="filter-bar mb-3">
    <a href="/tasks" class="filter-item">All</a>
    <a href="/tasks?filter=soon" class="filter-item">Soon</a>
    <a href="/tasks?filter=overdue" class="filter-item">Overdue</a>
    <a href="/tasks?filter=done" class="filter-item">Done</a>
    <a href="/me/trash-tasks" class="filter-item">Trash</a>
  </div>
  <!-- TASK LIST -->
  <div class="task-list">
    {{#each tasks}}
    <div class="task-card card">
      <div class="card-body">
        <!-- TOP -->
        <div class="d-flex justify-content-between align-items-start">
          <!-- TITLE -->
          <h5 class="task-title mb-1">
            <a href="/tasks/{{_id}}">{{title}}</a>
          </h5>
          <!-- STATUS -->
          <span class="status {{status}}"> {{status}} </span>
        </div>
        <!-- DESCRIPTION (ADD NHẸ) -->
        {{#if description}}
        <p class="task-desc text-muted mb-2">{{description}}</p>
        {{/if}}
        <!-- META -->
        <div class="task-meta mt-2">
          <span>📅 {{formatDate deadline}}</span>
        </div>
        <!-- ACTION -->
        <div class="task-actions mt-3">
          <form method="POST" action="/tasks/{{_id}}/status?_method=PATCH">
            <button class="btn btn-sm btn-success">
              {{#if (eq status "done")}} Undo {{else}} Done {{/if}}
            </button>
          </form>
          <a href="/tasks/{{_id}}/edit" class="btn btn-sm btn-warning">
            Edit
          </a>
          <form method="POST" action="/tasks/{{_id}}?_method=DELETE">
            <button class="btn btn-sm btn-danger">Delete</button>
          </form>
        </div>
      </div>
    </div>
    {{else}}
    <div class="empty-state">
      <h5>No tasks found</h5>
      <small>Try changing filter or create a new task 🚀</small>
    </div>
    {{/each}}
  </div>
</div>
