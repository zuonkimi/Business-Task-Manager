<div class="task-form">
  <!-- HEADER -->
  <div
    class="task-list-header d-flex justify-content-between align-items-center mb-3"
  >
    <h2><i class="bi bi-trash3"></i> Trash Tasks</h2>
    <button class="btn btn-outline-secondary" onclick="goBackPrevPage()">
      Back
    </button>
  </div>
  <!-- LIST -->
  <div class="trash-list">
    {{#each tasks}}
    <div class="card mb-2 shadow-sm">
      <div class="card-body">
        <!-- TITLE -->
        <h5 class="mb-1">{{title}}</h5>
        <!-- DESCRIPTION -->
        <p class="text-muted mb-2">{{description}}</p>
        <!-- DEADLINE -->
        <div class="text-muted mb-2">
          <i class="bi bi-calendar-heart"></i> {{formatDate deadline}}
        </div>
        <!-- ACTION -->
        <div class="d-flex gap-2">
          <button
            type="button"
            class="btn btn-sm btn-warning"
            onclick="restoreTask('{{_id}}')"
          >
            <i class="bi bi-arrow-repeat"></i> Restore
          </button>
          <button
            type="button"
            class="btn btn-sm btn-danger"
            data-bs-toggle="modal"
            data-bs-target="#deleteModal"
            data-id="{{_id}}"
          >
            <i class="bi bi-calendar-x-fill"></i> Destroy
          </button>
        </div>
      </div>
    </div>
    {{else}}
    <div class="text-center text-muted mt-4">
      <h5>Thùng rác trống</h5>
    </div>
    {{/each}}
  </div>
</div>
<div class="modal fade" id="deleteModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Xác nhận</h5>
        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="modal"
        ></button>
      </div>
      <div class="modal-body">Bạn chắc muốn xóa vĩnh viễn task này?</div>
      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
        <button class="btn btn-danger" id="confirmDeleteBtn">Xóa</button>
      </div>
    </div>
  </div>
</div>
<form id="deleteForm" method="POST"></form>
<form id="restoreForm" method="POST"></form>

<script>
  // SET ID khi mở modal
  const destroyModal = document.getElementById('deleteModal');
  const destroyBtn = document.getElementById('confirmDeleteBtn');
  let deleteId = null;

  destroyModal.addEventListener('show.bs.modal', event => {
    const button = event.relatedTarget;
    deleteId = button.getAttribute('data-id');
  });
  // DESTROY (xóa vĩnh viễn)
  destroyBtn.onclick = async () => {
    if (!deleteId) return;
    destroyBtn.disabled = true;
    try {
      await fetch(`/tasks/${deleteId}/force`, { method: 'DELETE' });
      const card = document
        .querySelector(`button[data-id="${deleteId}"]`)
        .closest('.card');
      if (card) card.remove();
      if (document.querySelectorAll('.trash-list .card').length === 0) {
        document.querySelector('.trash-list').innerHTML = `
        <div class="text-center text-muted mt-4">
          <h5>Thùng rác trống</h5>
        </div>`;
      }
      // CLOSE MODAL HERE
      const modalEl = document.getElementById('deleteModal');
      const modalInstance = bootstrap.Modal.getInstance(modalEl);
      modalInstance.hide();
    } catch (err) {
      console.error(err);
      alert('Có lỗi khi xóa vĩnh viễn');
    } finally {
      destroyBtn.disabled = false;
    }
  };

  // RESTORE
  window.restoreTask = async id => {
    const btn = document.querySelector(
      `button[onclick*="restoreTask('${id}')"]`,
    );
    if (btn) btn.disabled = true;
    try {
      await fetch(`/tasks/${id}/restore?_method=PATCH`, {
        method: 'POST',
      });
      // Update DOM ngay
      const card = document
        .querySelector(`button[onclick*="restoreTask('${id}')"]`)
        .closest('.card');
      if (card) card.remove();
      // Kiểm tra empty state
      if (document.querySelectorAll('.trash-list .card').length === 0) {
        document.querySelector('.trash-list').innerHTML = `
          <div class="text-center text-muted mt-4">
            <h5>Thùng rác trống</h5>
          </div>`;
      }
    } catch (err) {
      console.error(err);
      alert('Có lỗi khi restore');
    } finally {
      if (btn) btn.disabled = false;
    }
  };

  // Back button
  window.goBackPrevPage = () => {
    if (window.history.length > 1) {
      window.history.go(-1);
    } else {
      window.location.href = '/tasks';
    }
  };
</script>
