<div class="login-page auth-page">
  <div class="info-box">
    <div class="auth-header">
      <h2>Welcome Back</h2>
      <p>Sign in to continue your productivity journey</p>
    </div>

    <form method="POST" action="/auth/login">
      <input type="hidden" name="_csrf" value="{{csrfToken}}" />

      <div class="input-box">
        <i class="bi bi-envelope-at-fill input-icon"></i>
        <input type="email" name="email" placeholder="Email..." required />
      </div>

      <div class="input-box">
        <i class="bi bi-person-fill-lock input-icon"></i>
        <input
          type="password"
          name="password"
          placeholder="Password..."
          required
        />
      </div>

      {{#if error}}
      <div class="alert alert-danger">{{error}}</div>
      {{/if}}

      <button class="btn-submit">Login</button>
    </form>

    <div class="social-submit">
      <a href="/auth/google" class="btn-social"><i class="bi bi-google"></i></a>
      <a href="/auth/facebook" class="btn-social"
        ><i class="bi bi-facebook"></i
      ></a>
      <a href="/auth/line" class="btn-social"><i class="bi bi-line"></i></a>
    </div>

    <p class="get-account">
      Don't have an account?
      <a href="/auth/register">Register</a>
    </p>
  </div>
</div>
