<div class="task-detail">
  <div class="task-main">
    <!-- LEFT: MEDIA -->
    <div class="task-left">
      {{#if task.attachments}} {{#each task.attachments}} {{#if (includes type
      "image")}}
      <img src="{{url}}" class="media" />
      {{else}}
      <video controls class="media">
        <source src="{{url}}" />
      </video>
      {{/if}} {{/each}} {{/if}}
    </div>

    <!-- RIGHT -->
    <div class="task-right">
      <!-- POST INFO -->
      <div class="task-info">
        <!-- HEADER (COMPACT) -->
        <div class="task-header">
          <img src="{{task.author.avatar}}" class="avatar" />

          <div class="task-meta">
            <div class="name-line">
              <strong>{{task.author.name}}</strong>
              <span>• {{formatDate task.createdAt}}</span>
            </div>

            {{#if task.tags}}
            <div class="tags">
              {{#each task.tags}}
              <span class="tag">#{{this}}</span>
              {{/each}}
            </div>
            {{/if}}
          </div>
        </div>

        <!-- TITLE (SMALLER, NOT HERO) -->
        <h3 class="title">{{task.title}}</h3>
      </div>

      <!-- COMMENT INPUT -->
      <div class="comment-input-box">
        <input type="text" placeholder="Write a comment..." />
        <button>Send</button>
      </div>

      <!-- COMMENT LIST -->
      <div class="comment-box">
        <div class="comment-list">
          {{#each task.comments}}
          <div class="comment-item">
            <div class="comment-user">
              <strong>{{this.user.name}}</strong>
              <span>{{formatDate this.createdAt}}</span>
            </div>

            <p>{{this.content}}</p>
          </div>
          {{/each}}
        </div>
      </div>
    </div>
  </div>
</div>
