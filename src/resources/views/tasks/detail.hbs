<div class="task-detail">
  <div class="task-main">
    <!-- LEFT: MEDIA -->
    <div class="task-left">
      {{#if task.attachments}} {{#each task.attachments}} {{#if (includes type
      "image")}}
      <img src="{{url}}" class="media" />
      {{else}}
      <video controls class="media">
        <source src="{{url}}" />
      </video>
      {{/if}} {{/each}} {{/if}}
    </div>

    <!-- RIGHT -->
    <div class="task-right">
      <!-- POST INFO -->
      <div class="task-info">
        <!-- HEADER (COMPACT) -->
        <div class="task-header">
          <img src="{{task.author.avatar}}" class="avatar" />

          <div class="task-meta">
            <div class="name-line">
              <strong>{{task.author.name}}</strong>
              <span>• {{formatDate task.createdAt}}</span>
            </div>

            {{#if task.tags}}
            <div class="tags">
              {{#each task.tags}}
              <span class="tag">#{{this}}</span>
              {{/each}}
            </div>
            {{/if}}
          </div>
        </div>

        <!-- TITLE (SMALLER, NOT HERO) -->
        <h3 class="title">{{task.title}}</h3>
      </div>

      <!-- COMMENT INPUT -->
      <div class="comment-input-box">
        <input
          id="comment-input"
          type="text"
          placeholder="Write a comment..."
        />
        <button id="comment-btn" data-task="{{task._id}}">Send</button>
      </div>

      <!-- COMMENT LIST -->
      <div class="comment-box">
        <div class="comment-list">
          {{#each comments}}
          <div class="comment-item">
            <!-- AVATAR -->
            <img class="comment-avatar" src="{{this.user.avatar}}" />

            <!-- BODY -->
            <div class="comment-body">
              <!-- HEADER -->
              <div class="comment-header">
                <strong class="comment-name">{{this.user.name}}</strong>

                <button class="delete-comment-btn" data-id="{{this._id}}">
                  <i class="bi bi-x-square"></i>
                </button>
              </div>

              <!-- CONTENT -->
              <div class="comment-content">{{this.content}}</div>

              <!-- FOOTER -->
              <div class="comment-footer">
                <button class="reply-btn" data-id="{{this._id}}">Reply</button>

                <button class="like-comment-btn" data-id="{{this._id}}">
                  <i class="bi bi-hand-thumbs-up-fill"></i>
                  {{this.likeCount}}
                </button>

                <span class="comment-time"> {{timeAgo this.createdAt}} </span>
              </div>
            </div>
          </div>
          {{/each}}
        </div>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const input = document.getElementById('comment-input');
      const btn = document.getElementById('comment-btn');
      const list = document.querySelector('.comment-list');

      if (!input || !btn || !list) return;
      const taskId = btn.dataset.task;
      if (!taskId) return;
      const API = '/api/comments';

      // RENDER COMMENT
      const renderComment = c => {
        if (!c?.user) return;
        const html = `
      <div class="comment-item">
        <img class="comment-avatar" src="${c.user.avatar || ''}" />
        <div class="comment-body">
          <div class="comment-header">
            <strong class="comment-name">${c.user.name || 'Unknown'}</strong>
            <button class="delete-comment-btn" data-id="${c._id}">
              <i class="bi bi-x-square"></i>
            </button>
          </div>
          <div class="comment-content">
            ${c.content || ''}
          </div>
          <div class="comment-footer">
            <button class="reply-btn" data-id="${c._id}">
              Reply
            </button>
            <button class="like-comment-btn" data-id="${c._id}">
              <i class="bi bi-suit-heart-fill"></i>
               ${c.likeCount || 0}
            </button>
            <span class="comment-time">just now</span>
          </div>
        </div>
      </div>
    `;
        list.insertAdjacentHTML('afterbegin', html);
      };

      // ADD COMMENT
      btn.addEventListener('click', async () => {
        const content = input.value.trim();
        if (!content) return;
        btn.disabled = true;
        try {
          const res = await fetch('/api/comments', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              content,
              taskId,
            }),
          });
          const data = await res.json();
          if (!res.ok || !data.success) {
            throw new Error('Create failed');
          }
          renderComment(data.comment);
          input.value = '';
        } catch (err) {
          console.error(err);
        } finally {
          btn.disabled = false;
        }
      });

      // EVENT DELEGATION
      list.addEventListener('click', async e => {
        const likeBtn = e.target.closest('.like-comment-btn');
        const replyBtn = e.target.closest('.reply-btn');
        const deleteBtn = e.target.closest('.delete-comment-btn');
        // ===== LIKE =====
        if (likeBtn) {
          const id = likeBtn.dataset.id;
          const res = await fetch(`${API}/${id}/like`, {
            method: 'POST',
          });
          const data = await res.json();
          if (data?.likeCount !== undefined) {
            likeBtn.innerHTML = `<i class="bi bi-hand-thumbs-up-fill"></i>${data.likeCount}`;
          }
        }
        // ===== REPLY =====
        if (replyBtn) {
          input.dataset.replyTo = replyBtn.dataset.id;
          input.placeholder = 'Replying...';
          input.focus();
        }
        // ===== DELETE =====
        if (deleteBtn) {
          const id = deleteBtn.dataset.id;
          if (!confirm('Delete this comment?')) return;
          try {
            const res = await fetch(`/api/comments/${id}`, {
              method: 'DELETE',
            });
            const data = await res.json();
            deleteBtn.closest('.comment-item')?.remove();
          } catch (err) {
            console.error(err);
          }
        }
      });
    });
  </script>
</div>
