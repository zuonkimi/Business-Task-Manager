<div class="task-form">
  <div class="task-list-header">
    <h2>📋 Todo List</h2>
    <button class="btn btn-outline-secondary" onclick="goBackHome()">
      Back
    </button>
  </div>

  <table class="table table-bordered">
    <thead>
      <tr>
        <th>Task</th>
        <th>Description</th>
        <th>Deadline</th>
        <th>Tag</th>
        <th>Status</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      {{#each tasks}}
      <tr class="{{taskStatusClass this}}">
        <td>{{title}}</td>
        <td>{{description}}</td>
        <td>{{formatDate deadline}}</td>
        <td>{{tags}}</td>
        <td>{{status}}</td>
        <td>
          <form
            action="/tasks/{{_id}}/status?_method=PATCH"
            method="POST"
            style="display: inline"
          >
            <button type="submit" class="btn btn-sm btn-success">✔</button>
          </form>
          <form
            action="/tasks/{{_id}}?_method=DELETE"
            method="POST"
            style="display: inline"
          >
            <button type="submit" class="btn btn-sm btn-danger">❌</button>
          </form>
        </td>
      </tr>
      {{else}}
      <tr>
        <td colspan="5" class="text-center text-muted py-4">
          {{emptyMessage}}
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>

<script>
  function goBackHome() {
    if (document.referrer && document.referrer !== window.location.href) {
      history.back();
    } else {
      window.location.href = '/home'; // fallback
    }
  }
</script>
