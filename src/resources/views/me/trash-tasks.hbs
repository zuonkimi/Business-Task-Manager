<div class="task-form">
  <!-- HEADER -->
  <div
    class="task-list-header d-flex justify-content-between align-items-center mb-3"
  >
    <h2>🗑 Trash Tasks</h2>
    <button class="btn btn-outline-secondary" onclick="goBackPrevPage()">
      Back
    </button>
  </div>
  <!-- LIST -->
  <div class="trash-list">
    {{#each tasks}}
    <div class="card mb-2 shadow-sm">
      <div class="card-body">
        <!-- TITLE -->
        <h5 class="mb-1">{{title}}</h5>
        <!-- DESCRIPTION -->
        <p class="text-muted mb-2">{{description}}</p>
        <!-- DEADLINE -->
        <div class="text-muted mb-2">📅 {{formatDate deadline}}</div>
        <!-- ACTION -->
        <div class="d-flex gap-2">
          <button
            type="button"
            class="btn btn-sm btn-warning"
            onclick="restoreTask('{{_id}}')"
          >
            ♻️ Restore
          </button>
          <button
            type="button"
            class="btn btn-sm btn-danger"
            data-bs-toggle="modal"
            data-bs-target="#deleteModal"
            data-id="{{_id}}"
          >
            💀 Destroy
          </button>
        </div>
      </div>
    </div>
    {{else}}
    <div class="text-center text-muted mt-4">
      <h5>Thùng rác trống</h5>
    </div>
    {{/each}}
  </div>
</div>
<div class="modal fade" id="deleteModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Xác nhận</h5>
        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="modal"
        ></button>
      </div>
      <div class="modal-body">Bạn chắc muốn xóa vĩnh viễn task này?</div>
      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
        <button class="btn btn-danger" id="confirmDeleteBtn">Xóa</button>
      </div>
    </div>
  </div>
</div>
<form id="deleteForm" method="POST"></form>
<form id="restoreForm" method="POST"></form>

<script>
  const destroyModal = document.getElementById('deleteModal');
  const destroyBtn = document.getElementById('confirmDeleteBtn');
  let deleteId = null;

  // SET ID khi mở modal
  destroyModal.addEventListener('show.bs.modal', event => {
    const button = event.relatedTarget;
    deleteId = button.getAttribute('data-id');
  });

  // DELETE HARD
  destroyBtn.onclick = async () => {
    const form = document.getElementById('deleteForm');
    await fetch(`/tasks/${deleteId}/force`, {
      method: 'DELETE',
    });
    location.reload();
  };
  // RESTORE
  const restoreTask = async id => {
    await fetch(`/tasks/${id}/restore?_method=PATCH`, {
      method: 'POST',
    });
    location.reload();
  };
  // BACK
  const goBackPrevPage = () => {
    if (window.history.length > 1) {
      window.history.go(-1);
    } else {
      window.location.href = '/tasks';
    }
  };
</script>
